{
  "ConnectionStrings": {
    "SmsHubNext": "Server=.;Database=SmsHubNext;Trusted_Connection=True;Application Name=SmsHubNext;MultipleActiveResultSets=True;TrustServerCertificate=true"
  },
  "DataProtection": {
    "KeyRingPath": "App_Data/DataProtection-Keys"
  },
  "BearerTokens": {
    "Key": "This is my shared key, not so secret, secret!!@#",
    "Issuer": "https://aban360.ir/",
    "Audience": "Any",
    "AccessTokenExpirationMinutes": 560,
    "RefreshTokenExpirationMinutes": 810,
    "AllowMultipleLoginsFromTheSameUser": false,
    "AllowSignoutAllUserActiveClients": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Dispatch": {
    "PollInterval": "00:00:02",
    "HoldRetryDelay": "00:00:30",
    "DispatchLeaseTimeout": "00:05:00",
    "MaxDispatchAttempts": 5,
    "MinAwaitingConfirmationAge": "00:02:00",
    "AwaitingConfirmationRetryDelay": "00:02:00",
    "RequiredNegativeConfirmations": 2,
    "RetryBackoffSeconds": [ 30, 120, 300, 900 ]
  },
  "DeliveryReportPolling": {
    "PollInterval": "00:00:15",
    "RetryDelay": "00:02:00",
    "StatusWindow": "1.00:00:00",
    "BatchSize": 100
  },
  "InboundPolling": {
    "Enabled": false,
    "PollInterval": "00:00:30",
    "BatchSize": 50
  },
  "Providers": {
    "Magfa": {
      "Enabled": false,
      "BaseUrl": "https://sms.magfa.com",
      "Timeout": "00:00:30",
      "BatchSize": 100
    },
    "Kavenegar": {
      "Enabled": false,
      "BaseUrl": "https://api.kavenegar.com",
      "Timeout": "00:00:30",
      "BatchSize": 200
    }
  },
  "AllowedHosts": "*"
}
